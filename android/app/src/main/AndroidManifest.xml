<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Required on Android 13+ to display notifications.
         Without this, FCM messages arrive but the system suppresses them. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <!-- Required for fullScreenIntent notifications (lock-screen alarm popups). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>
    <!-- Required to turn the screen on when a new order arrives. -->
    <uses-permission android:name="android.permission.TURN_SCREEN_ON"/>
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD"/>
    <!-- Required to request battery optimization exemption so the background
         Dart isolate survives on OEM devices (Xiaomi, Samsung, Huawei). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <application
        android:label="Cmandili Partner"
        android:name=".Application"
        android:icon="@mipmap/launcher_icon">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Required so taps on FCM notifications open the app. -->
            <intent-filter>
                <action android:name="FLUTTER_NOTIFICATION_CLICK"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        <!-- Default channel id used when an FCM `notification` payload omits one.
             Must match the channel created by flutter_local_notifications below. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="cmandili_orders" />
        <!-- Default icon used when the OS renders an FCM notification while the
             app is killed. Without this, Android silently drops the notification
             because the small-icon resource can't be resolved from the dead
             process's runtime channel registration. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/launcher_icon" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Remove the Flutter plugin's default FCM service so only our custom
             service (below) handles incoming messages. Without this removal,
             the manifest merger keeps both and FCM dispatches only to the
             higher-priority entry — which is undefined, causing missed messages. -->
        <service
            android:name="io.flutter.plugins.firebase.messaging.FlutterFirebaseMessagingService"
            tools:node="remove" />

        <!-- CmandiliMessagingService extends FlutterFirebaseMessagingService.
             Native Kotlin runs in milliseconds — reliable even on OEM Android
             when the app is terminated and the Dart isolate is killed too quickly.
             super.onMessageReceived() still fires the Dart background handler
             as a bonus for stock Android in-app state updates. -->
        <service
            android:name=".CmandiliMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
